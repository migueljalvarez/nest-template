{
  "name": "nest-template",
  "version": "1.0.0",
  "description": "Nestjs template started for begin a new backend projects",
  "main": "index.js",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write src/**/*.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/migueljalvarez/nest-template.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/migueljalvarez/nest-template/issues"
  },
  "homepage": "https://github.com/migueljalvarez/nest-template#readme",
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "11.1.6",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "@nestjs/swagger": "11.2.0",
    "@nestjs/terminus": "11.0.0",
    "axios": "1.13.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "joi": "18.0.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.3.0",
    "eslint": "9.34.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.6.2",
    "tsc-alias": "1.8.16",
    "typescript-eslint": "8.41.0"
  },
  "engines": {
    "node": "22.11.x",
    "npm": "11.5.2"
  }
}